# Server
PORT=4242
BASE_URL=http://localhost:4242

# Stripe — use test keys locally, production keys only in prod env vault
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Internal tokens — generate with: openssl rand -hex 32
JOB_TOKEN=replace_with_strong_random_token
ADMIN_KEY=replace_with_strong_random_token

# API key for the demo merchant seeded at startup.
# Generate with: openssl rand -hex 24
# If omitted a random key is generated on first run (check server logs).
DEMO_MERCHANT_API_KEY=replace_with_strong_random_token

# Comma-separated list of allowed CORS origins (no trailing slashes)
CORS_ORIGINS=http://localhost:4242,http://localhost:3000
